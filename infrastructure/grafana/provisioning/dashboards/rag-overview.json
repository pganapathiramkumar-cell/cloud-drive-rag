{
  "title": "Enterprise RAG — Overview",
  "uid": "rag-overview",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Queries",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rag_queries_total)", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(rag_queries_total{status='error'}[5m])) / sum(rate(rag_queries_total[5m]))", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "Active Sessions",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "rag_active_sessions", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "Total Chunks Stored",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rag_chunks_created_total)", "refId": "A" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Query Latency (p50 / p95 / p99)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Node Latency by Stage",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(rag_node_duration_seconds_bucket[5m])) by (node)", "legendFormat": "{{node}}", "refId": "A" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "LLM Tokens / min",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(rag_llm_tokens_total[1m]) * 60", "refId": "A" }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Docs Ingested / min",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(rag_docs_ingested_total{status='success'}[1m]) * 60", "refId": "A" }]
    }
  ]
}
