{
  "realm": "enterprise-rag",
  "enabled": true,
  "displayName": "Enterprise RAG",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "sslRequired": "none",

  "roles": {
    "realm": [
      { "name": "user",  "description": "Standard RAG query access" },
      { "name": "admin", "description": "Full access including ingestion" }
    ]
  },

  "clients": [
    {
      "clientId": "rag-frontend",
      "name": "RAG Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:3000/*", "https://*.vercel.app/*"],
      "webOrigins": ["http://localhost:3000", "https://*.vercel.app"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "rag-backend",
      "name": "RAG Backend",
      "enabled": true,
      "bearerOnly": true
    }
  ],

  "users": [
    {
      "username": "testuser",
      "email": "testuser@example.com",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "testpass", "temporary": false }],
      "realmRoles": ["user"]
    },
    {
      "username": "adminuser",
      "email": "adminuser@example.com",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "adminpass", "temporary": false }],
      "realmRoles": ["user", "admin"]
    }
  ]
}
