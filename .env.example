# ── Groq (LLM) ───────────────────────────────────────────────────────────────
# Free key at console.groq.com — no credit card needed
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cohere (Embeddings) ───────────────────────────────────────────────────────
# Free key at dashboard.cohere.com — replaces local SBERT/PyTorch (~500 MB saved)
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Qdrant (Vector Store) ─────────────────────────────────────────────────────
# Local dev:   docker-compose up qdrant  →  http://localhost:6333  (no API key)
# Production:  create free cluster at cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=enterprise_rag

# ── Redis (Session Memory) ────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Production: get free URL at upstash.com (rediss://default:<token>@<host>:6379)
REDIS_URL=redis://localhost:6379

# ── Keycloak (Auth — skip with DEBUG=true) ────────────────────────────────────
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=enterprise-rag
KEYCLOAK_CLIENT_ID=rag-backend

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=enterprise-rag-backend

# ── Google OAuth (Drive integration) ─────────────────────────────────────────
# 1. console.cloud.google.com → APIs & Services → Enable "Google Drive API"
# 2. Credentials → Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:8000/v1/drive/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/drive/callback
FRONTEND_URL=http://localhost:3000

# ── Dev bypass ────────────────────────────────────────────────────────────────
DEBUG=true   # accepts dev-token, skips Keycloak — set false in production

# ── Frontend (Vercel env vars — set in Vercel dashboard) ─────────────────────
VITE_API_URL=https://your-render-service.onrender.com
VITE_SKIP_AUTH=true
